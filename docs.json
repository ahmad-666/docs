{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CUFinder",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "tabler"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Customization",
            "pages": ["essentials/settings", "essentials/navigation"]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "href": "/apis",
    "light": "/images/logos/logo.png",
    "dark": "/images/logos/logo-text-white.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact Sales",
        "href": "https://cufinder.io/contact-sales"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.cufinder.io/auth/signin"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/cu_finder",
      "github": "https://github.com/CUFinder",
      "youtube": "https://www.youtube.com/@cufinderco",
      "instagram": "https://www.instagram.com/cufinder.io",
      "facebook": "https://www.facebook.com/cufinder",
      "linkedin": "https://www.linkedin.com/company/cufinder"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/apis",
      "permanent": true
    }
  ]
}
